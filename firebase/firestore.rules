rules_version = '2';
// ============================================================
// VIGÍA 54 — Firestore Security Rules (RNF1)
// Role-based access control via custom claims
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────
    function isSignedIn()  { return request.auth != null; }
    function uid()         { return request.auth.uid; }
    function role()        { return get(/databases/$(database)/documents/users/$(uid())).data.role; }
    function isCiudadano() { return isSignedIn() && role() == 'ciudadano'; }
    function isAgente()    { return isSignedIn() && role() == 'agente'; }
    function isAdmin()     { return isSignedIn() && role() == 'admin'; }
    function isStaff()     { return isAgente() || isAdmin(); }

    // ── Users collection ────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read their own doc
      allow read: if isSignedIn() && uid() == userId;
      // Agents and admins can read all users
      allow read: if isStaff();
      // Users can create their own doc on registration
      allow create: if isSignedIn() && uid() == userId;
      // Users can update their own profile (not role/trustScore)
      allow update: if isSignedIn() && uid() == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role','trustScore','falseAlarms','verifiedReports']);
      // Only admins can update role
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Reports collection ──────────────────────────────────
    match /reports/{reportId} {
      // All authenticated users can read verified reports
      allow read: if isSignedIn();
      // Citizens can create reports (not set aiScore or status)
      allow create: if isSignedIn()
        && request.resource.data.authorId == uid()
        && request.resource.data.status == 'pending'
        && request.resource.data.aiScore == null;
      // Agents and admins can update status
      allow update: if isStaff();
      // Admins can delete
      allow delete: if isAdmin();
      // Allow Cloud Functions to write (via admin SDK, bypasses rules)
    }

    // ── Analytics collection ────────────────────────────────
    match /analytics/{districtId} {
      // Anyone can read analytics (public data)
      allow read: if true;
      // Only Cloud Functions (admin SDK) can write
      allow write: if false;
    }

    // ── ETL Jobs collection (admin only) ────────────────────
    match /etl_jobs/{jobId} {
      allow read, write: if isAdmin();
    }
  }
}
