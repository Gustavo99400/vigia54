rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función helper para verificar si el usuario logueado es administrador activo
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/administradores/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/administradores/$(request.auth.uid)).data.activo != false;
    }

    // Reglas para incidentes reportados
    match /incidentes/{incidente} {
      allow read: if true; // El mapa de la pantalla principal es de acceso público
      allow create: if request.auth != null && request.resource.data.usuarioId == request.auth.uid;
      allow update, delete: if isAdmin(); // Solo administradores de campo/sistema pueden actualizar o eliminar tickets
    }
    
    // Reglas para perfiles de ciudadanos
    match /usuarios/{usuario} {
      allow read: if request.auth != null; // Requiere autenticación para leer perfiles ajenos
      allow write: if request.auth != null && request.auth.uid == usuario; // Solo el propio usuario puede modificar sus datos (ej. trust_score)
    }
    
    // Reglas para administradores
    match /administradores/{admin} {
      allow read: if request.auth != null; // Para poder corroborar el rol en AuthContext
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/administradores/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/administradores/$(request.auth.uid)).data.rol == "admin_sistema"; // Solo un superadmin puede crear/editar administradores
    }
    
    // Reglas para unidades y patrullas de Arequipa
    match /unidades/{unidad} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
